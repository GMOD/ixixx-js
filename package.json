{
  "name": "ixixx",
  "version": "3.0.3",
  "description": "JavaScript implementation of trix text indexing",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/GMOD/ixixx-js.git"
  },
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./esm/index.js",
      "require": "./dist/index.js"
    }
  },
  "author": {
    "name": "Colin Diesh",
    "email": "colin.diesh@gmail.com",
    "url": "https://github.com/cmdcolin"
  },
  "files": [
    "dist",
    "esm",
    "src"
  ],
  "bin": {
    "ixixxjs": "./dist/bin.js"
  },
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint --report-unused-disable-directives --max-warnings 0",
    "clean": "rimraf dist esm",
    "prebuild": "yarn clean",
    "build:esm": "tsc --outDir esm",
    "build:es5": "tsc --module commonjs --moduleResolution bundler --outDir dist",
    "build": "yarn build:esm && yarn build:es5",
    "postbuild:es5": "echo '{\"type\": \"commonjs\"}' > dist/package.json",
    "test": "vitest",
    "preversion": "yarn lint && yarn test --run && yarn build",
    "postversion": "git push --follow-tags"
  },
  "dependencies": {
    "@jbrowse/quick-lru": "^7.3.5",
    "command-exists": "^1.2.9",
    "split2": "^4.2.0",
    "tmp": "^0.2.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/command-exists": "^1.2.3",
    "@types/node": "^25.5.0",
    "@types/split2": "^4.2.3",
    "@types/tmp": "^0.2.6",
    "eslint": "^9.39.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-unicorn": "^64.0.0",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.57.2",
    "vitest": "^4.1.2"
  },
  "publishConfig": {
    "access": "public"
  }
}
